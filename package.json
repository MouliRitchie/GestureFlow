{
  "name": "gestureflow",
  "version": "1.0.0",
  "description": "Control your PC with hand gestures",
  "author": "Mouli",
  "main": "electron-main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "package": "vite build && electron-builder"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0",
    "vite": "^5.4.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.gestureflow.app",
    "productName": "GestureFlow",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "dist/**",
      "electron-main/**",
      "backend/**",
      "gesture_config.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ]
  }
}